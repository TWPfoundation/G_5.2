# G_5.2 Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored. This file is safe to commit.

# ── OpenRouter ──────────────────────────────────────────────────────────────────
# Single API key routes both OpenAI and Anthropic models.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model overrides (optional — defaults shown)
# Verify model slugs at: https://openrouter.ai/models
# Direct Azure OpenAI (preferred primary OpenAI path)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEFAULT_MODEL=gpt-5.4

# OpenRouter fallback for OpenAI-family requests. Use OpenRouter model IDs
# here. Pin an exact dated slug if you want fallback runs to match a verified
# provider/model combination exactly.
OPENROUTER_OPENAI_MODEL=openai/gpt-5.4-20260305
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.4-20260305
OPENROUTER_SECONDARY_MODEL=openai/gpt-5.4-mini
OPENROUTER_ANTHROPIC_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_GEMINI_MODEL=google/gemini-3.1-pro-preview-20260219
# Keep the fallback route Azure-aware, but do not hard-require Azure here; the
# direct Azure provider is already the primary path.
OPENROUTER_OPENAI_PROVIDER_ORDER=azure,openai
OPENROUTER_OPENAI_PROVIDER_IGNORE=none
OPENROUTER_OPENAI_ALLOW_FALLBACKS=true
OPENROUTER_OPENAI_MAX_COMPLETION_TOKENS=48000
# Legacy alias for OpenAI ignore-routing.
OPENROUTER_IGNORE_PROVIDERS=none

# Eval/default provider selection
# One of: azure, anthropic, openai, openai-secondary, gemini
EVAL_PROVIDER=azure

# ── Supabase ────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── S3-Compatible Object Storage (Witness Publication Delivery) ─────────────────
# Works with Supabase Storage, AWS S3, MinIO, Cloudflare R2, etc.
S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
S3_REGION=eu-west-1
S3_BUCKET=witness-publications
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# ── Runtime ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
