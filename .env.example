# G_5.2 Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored. This file is safe to commit.

# ── OpenRouter ──────────────────────────────────────────────────────────────────
# Single API key routes both OpenAI and Anthropic models.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model overrides (optional — defaults shown)
# Verify model slugs at: https://openrouter.ai/models
OPENROUTER_OPENAI_MODEL=openai/gpt-4.5
OPENROUTER_ANTHROPIC_MODEL=anthropic/claude-sonnet-4-5

# ── Supabase ────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── Runtime ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
